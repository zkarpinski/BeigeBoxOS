{
  "name": "@retro-web/karpos",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build && node scripts/write-cloudflare-routes.js",
    "start": "next start",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx"
  },
  "dependencies": {
    "@retro-web/app-winamp": "workspace:*",
    "@retro-web/core": "workspace:*",
    "@supabase/supabase-js": "^2.99.1",
    "next": "^15.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@retro-web/config": "workspace:*",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jsdom": "^23.2.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5.0.0",
    "wrangler": "^4.70.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1",
      "^@win98/(.*)$": "<rootDir>/../win98/app/$1",
      "\\.css$": "<rootDir>/test/__mocks__/styleMock.js"
    },
    "testMatch": [
      "**/test/**/*.test.js",
      "**/test/**/*.test.ts",
      "**/*.test.ts",
      "**/*.test.tsx"
    ],
    "setupFilesAfterEnv": ["<rootDir>/test/setup.js"],
    "moduleFileExtensions": ["js", "ts", "tsx"],
    "testPathIgnorePatterns": ["/node_modules/"],
    "transform": {
      "\\.(ts|tsx)$": ["ts-jest", { "tsconfig": { "jsx": "react-jsx" } }]
    },
    "collectCoverageFrom": ["app/**/*.{ts,tsx,js}"],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "\\.test\\.(ts|tsx|js)$",
      "\\.spec\\.(ts|tsx|js)$",
      "\\.d\\.ts$",
      "next-env\\.d\\.ts$",
      "test/setup\\.js$"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 0,
        "branches": 0,
        "functions": 0,
        "lines": 0
      }
    }
  }
}
