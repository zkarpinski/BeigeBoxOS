{
  "name": "website",
  "version": "1.0.0",
  "description": "Windows 98",
  "scripts": {
    "test": "jest",
    "test:unit": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "test:playwright": "npx playwright test",
    "build": "next build && node scripts/write-cloudflare-routes.js",
    "dev": "next dev --turbopack",
    "start": "next start",
    "fmt": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx"
  },
  "config": {
    "s3Bucket": ""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.1",
    "next": "^15.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "clean-css": "^5.3.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "html-minifier-terser": "^7.2.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jsdom": "^23.2.0",
    "prettier": "^3.8.1",
    "terser": "^5.31.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.0.0",
    "wrangler": "^4.70.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    },
    "testMatch": [
      "**/test/**/*.test.js",
      "**/test/**/*.test.ts",
      "**/*.test.ts",
      "**/*.test.tsx"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/test/setup.js"
    ],
    "moduleFileExtensions": [
      "js",
      "ts",
      "tsx"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/"
    ],
    "transform": {
      "\\.(ts|tsx)$": [
        "ts-jest",
        {
          "tsconfig": {
            "jsx": "react-jsx"
          }
        }
      ]
    },
    "collectCoverageFrom": [
      "app/**/*.{ts,tsx,js}"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "\\.test\\.(ts|tsx|js)$",
      "\\.spec\\.(ts|tsx|js)$",
      "\\.d\\.ts$",
      "next-env\\.d\\.ts$",
      "test/setup\\.js$"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 0,
        "branches": 0,
        "functions": 0,
        "lines": 0
      }
    }
  }
}
