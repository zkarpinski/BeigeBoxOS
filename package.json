{
  "name": "website",
  "version": "1.0.0",
  "description": "Windows 98",
  "scripts": {
    "test": "jest && npx playwright test",
    "test:unit": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "test:playwright": "npx playwright test",
    "build": "node scripts/build.js",
    "minify": "node scripts/build.js",
    "build:bundle": "node scripts/build.js --bundle",
    "build:bundle:obfuscate": "node scripts/build.js --bundle --obfuscate",
    "deploy:cloudflare": "npm run build:bundle:obfuscate && npx wrangler pages deploy dist --project-name website"
  },
  "config": {
    "s3Bucket": ""
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "clean-css": "^5.3.3",
    "html-minifier-terser": "^7.2.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jsdom": "^23.2.0",
    "terser": "^5.31.0",
    "wrangler": "^4.70.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": [
      "**/test/**/*.test.js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/test/setup.js"
    ],
    "moduleFileExtensions": [
      "js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/"
    ],
    "collectCoverageFrom": [
      "shell/windows97.js",
      "shell/state.js",
      "apps/calculator/calculator.js",
      "apps/word/word.js"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 80,
        "branches": 70,
        "functions": 75,
        "lines": 80
      }
    }
  }
}
